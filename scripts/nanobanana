#!/bin/sh

script_dir=$(CDPATH= cd "$(dirname "$0")" && pwd)

if ! command -v uv >/dev/null 2>&1; then
  echo "Error: uv is required to run nanobanana." >&2
  echo "Run 'agh install --setup path' to install or check uv, or install uv from https://docs.astral.sh/uv/getting-started/installation/." >&2
  exit 127
fi

exec uv run --quiet --script "$script_dir/nanobanana.py" "$@"
